rules_version = '2';

service cloud.firestore {

  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/Roles/$(request.auth.uid)).data.role == "admin";
    }

    function isUserOwner(userId) {
      return request.auth.uid == userId;
    }

    function isOwnerOrAdmin(userId) {
      return isUserOwner(userId) || isAdmin();
    }

    match /Roles/{userId} {
      allow get: if isAuth() && isOwnerOrAdmin(userId);
      allow list: if isAuth() && isAdmin();
      allow write: if isAuth() && isAdmin();
    }

    match /Users/{userId} {
      allow get: if isAuth() && isOwnerOrAdmin(userId);
      allow list: if isAuth() && isAdmin();
      allow write: if isAuth() && isOwnerOrAdmin(userId);

      match /Regions/{regionId} {
        allow read: if isAuth() && isOwnerOrAdmin(userId);
        allow write: if isAuth() && isOwnerOrAdmin(userId);
    
        match /Instances/{instanceId} {
          allow read: if isAuth() && isOwnerOrAdmin(userId);
          allow write: if isAuth() && isOwnerOrAdmin(userId);
        }
      }
    }
    match /Live-Regions/{regionId} {
      allow read, list: if isAuth();
      allow write: if isAuth() && isAdmin();
    }
  }
}
