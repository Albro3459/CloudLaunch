# Manual stack testing only.
# Runtime CloudLaunch deploys do not read terraform.tfvars. The Deploy Lambda
# sends these values from the selected CloudLaunch.oci.regions.<region> entry in
# AWS Secrets Manager.

availability_domain     = "xJLJ:US-SANJOSE-1-AD-1"
region                  = "us-sanjose-1"
compartment_id          = "ocid1.tenancy.oc1...replace_me"
subnet_id               = "ocid1.subnet.oc1.us-sanjose-1...replace_me"
source_image_id         = "ocid1.image.oc1.us-sanjose-1...replace_me"

# OCI requires ssh-rsa!
ssh_authorized_keys = [
    "ssh-rsa ... example",
    "ssh-rsa ... example"
]

instance_display_name   = "CloudLaunch"
vnic_display_name       = "CloudLaunch"
ipv6_subnet_cidr        = "2603:c024:c01a:8b69::/64"
shape                   = "VM.Standard.A1.Flex"
shape_memory_in_gbs     = 1
shape_ocpus             = 1
boot_volume_size_in_gbs = 50
boot_volume_vpus_per_gb = 10

wg_interface                    = "wg0"
wg_listen_port                  = 51820
wg_address_v4                   = "10.0.0.1/24"
wg_address_v6                   = "fd42:42:42::1/64"
wg_network_v4                   = "10.0.0.0/24"
wg_network_v6                   = "fd42:42:42::/64"
wg_dns_address_v4               = "10.0.0.1"
wg_dns_address_v6               = "fd42:42:42::1"
wg_rate_limit                   = "25/second"
wg_rate_limit_burst             = 100
wg_server_private_key           = "..._WITH_SERVER_PRIVATE_KEY"
wg_client_public_key            = "..._WITH_CLIENT_PUBLIC_KEY"
wg_peer_allowed_ipv4            = "10.0.0.2/32"
wg_peer_allowed_ipv6            = "fd42:42:42::2/128"
wg_peer_persistent_keepalive    = 25

# Create your password with 'openssl passwd -6'
hashed_password = "$6$replace_with_real_salt$replace_with_real_hash_value"
